generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Status {
    PRESENT
    ABSENT
    HALF_DAY
    LEAVE
}

// --- MODELS ---
model User {
    id          Int     @id @default(autoincrement())
    fullname    String
    username    String  @unique
    email       String? @unique
    password    String
    isAdmin     Boolean @default(false)
    role        String  @default("Employee")
    avatar      String?
    pushToken   String? @db.Text
    shift_hours Float   @default(9.0)

    // Auth tokens
    access_token  String? @db.Text
    refresh_token String? @db.Text

    // Relations
    attendanceLogs AttendanceLogs[]
    events         Event[]
    participatedEvents Event[] @relation("EventParticipants")
    notifications  Notification[]

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Client {
    id          Int     @id @default(autoincrement())
    name        String  @unique
    description String? @db.Text

    // Relations
    attendanceLogs  AttendanceLogs[]
    attendanceTasks AttendanceTask[]
    events          Event[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AttendanceLogs {
    id   Int      @id @default(autoincrement())
    date DateTime @db.Date

    clock_in_time      DateTime
    clock_in_latitude  Float
    clock_in_longitude Float
    clock_in_address   String?

    clock_out_time      DateTime?
    clock_out_latitude  Float?
    clock_out_longitude Float?
    clock_out_address   String?

    status Status @default(PRESENT)

    // PLAN Phase (Clock-in)
    plannedClientId Int?
    plannedClient   Client? @relation(fields: [plannedClientId], references: [id])
    plannedDept     String?
    plannedTasks    String? @db.Text

    // Task Selection (Clock-in / PLAN)
    plannedTaskCategoryId Int?
    plannedTaskCategory   TaskCategory? @relation("PlannedTaskCategory", fields: [plannedTaskCategoryId], references: [id])
    plannedTaskId         Int?
    plannedTask           Task?         @relation("PlannedTask", fields: [plannedTaskId], references: [id])

    // DO, CHECK, ACT, FOLLOW UP Phase (Clock-out)
    reportTasksDone   String? @db.Text
    reportGuidance    String? @db.Text
    reportHandedOver  String? @db.Text
    reportTargetDate  String?
    reportResponsible String?
    reportStatus      String?

    // Task Selection (Clock-out)
    reportTaskCategoryId Int?
    reportTaskCategory   TaskCategory? @relation(fields: [reportTaskCategoryId], references: [id])
    reportTaskId         Int?
    reportTask           Task?         @relation(fields: [reportTaskId], references: [id])

    // Tasks Checklist (Multi-Task)
    attendanceTasks AttendanceTask[]

    // Relations
    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model TaskCategory {
    id    Int    @id @default(autoincrement())
    name  String @unique
    order Int    @default(0)

    tasks                 Task[]
    attendanceLogs        AttendanceLogs[]
    plannedAttendanceLogs AttendanceLogs[] @relation("PlannedTaskCategory")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Task {
    id    Int    @id @default(autoincrement())
    title String
    order Int    @default(0)

    // Relations
    categoryId            Int
    category              TaskCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    attendanceLogs        AttendanceLogs[]
    plannedAttendanceLogs AttendanceLogs[] @relation("PlannedTask")
    attendanceTasks       AttendanceTask[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AttendanceTask {
    id              Int            @id @default(autoincrement())
    attendanceLogId Int
    attendanceLog   AttendanceLogs @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)

    taskId Int
    task   Task @relation(fields: [taskId], references: [id])

    clientId   Int?
    client     Client? @relation(fields: [clientId], references: [id])
    department String?

    isCompleted Boolean @default(false)
    remarks     String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Event {
    id          Int      @id @default(autoincrement())
    title       String
    description String?  @db.Text
    start       DateTime
    end         DateTime
    allDay      Boolean  @default(false)
    type        String   @default("Meeting") // Meeting, Client Visit, Internal Task, Other
    color       String? // Based on type

    // Relations
    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    clientId Int?
    client   Client? @relation(fields: [clientId], references: [id])
    
    participants User[] @relation("EventParticipants")
    managers     String? @db.Text

    notifications Notification[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Notification {
    id           Int      @id @default(autoincrement())
    userId       Int
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    title        String
    message      String   @db.Text
    type         String   @default("INFO") // INFO, MEETING_REMINDER
    isRead       Boolean  @default(false)
    isSent       Boolean  @default(false)
    scheduledFor DateTime @default(now())
    
    eventId      Int?
    event        Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
